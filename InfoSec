This file contains the single SCI implmentation of the InfoSec solution.

There are two API calls Store and Get

1. Store
[TestMethod]
public void TestMethod_infosec_store()
{
    SET_DEV();
    string folder = Environment.GetEnvironmentVariable("Envionment");
    string sin = Environment.GetEnvironmentVariable("DeviceTestA");
    string userTokenPath = @"D:\Examples\VO\DeviceToken-" + sin + ".json";
    Fido.FidoProvider fp = new Fido.FidoProvider(userTokenPath);

    byte[] cnt = Encoding.UTF8.GetBytes("Test");
    string filename = "Test.txt";
    string vaultMeToken = Support.VaultMe(userTokenPath); 
    string jwk = SqlServer.Providers.JwtProvider.ExtractJwk(vaultMeToken);

    InfoSecToken tkn = new InfoSecToken();
    tkn.Jti = fp.RandomGuid();
    tkn.ObjectHash =  Shake256.HashData(cnt, 64); 
    tkn.ObjectId = new Guid(tkn.ObjectHash.TakeLast(16).ToArray());
    tkn.FileName = filename;
    tkn.JwToken = vaultMeToken;
    tkn.Counter = fp.GetCounter();
    tkn.LinkInfo = fp.Protect(cnt, vaultMeToken);   // Protect InfoSec 
    string msgInfo = tkn.Encode(fp);


    // Post InfoSecToken
    StringContent content = new StringContent(msgInfo);

    // Extract Function endpoint from User Token
    Uri _baseUri = new Uri(fp.Audience());
    // Build funtion endpoint Uri
    HttpClient _httpClient = new HttpClient();
    string _relativeUrl = "InfoSec/Store";
    Uri _uri = new Uri(_baseUri, _relativeUrl);
    _httpClient.BaseAddress = _baseUri;
    // Add User Jwtoken
    _httpClient.DefaultRequestHeaders.Add("x-token", fp.GetJwToken());
    HttpResponseMessage response = _httpClient.PostAsync(_uri, content).Result;
    if (response.IsSuccessStatusCode)
    {
        byte[] objectId = response.Content.ReadAsByteArrayAsync().Result;
     
    }
    else
    {
        // fail
        string error = response.Content.ReadAsStringAsync().Result;
        throw new Exception(error);
    }


}
2. Get
[TestMethod]
public void TestMethod_infosec_get()
{
    SET_DEV();
    
    string folder = Environment.GetEnvironmentVariable("Envionment");
    string sin = Environment.GetEnvironmentVariable("DeviceTestA");
    string userTokenPath = @"D:\Examples\VO\DeviceToken-" + sin + ".json";
    Fido.FidoProvider fp = new Fido.FidoProvider(userTokenPath);

    // Test -> Find an Object
    string objectId = ObjectStoreDB.List(fp.GetSecureIdentity()).LastOrDefault().ObjectId;

    // Extract Function endpoint from User Token
    var securityToken = new JwtSecurityToken(fp.GetJwToken());
    Uri _baseUri = new Uri(securityToken.Audiences.FirstOrDefault());
   
    // Build funtion endpoint Uri
    HttpClient _httpClient = new HttpClient();
    string _relativeUrl = "InfoSec/Get?id="+ objectId;
    Uri _uri = new Uri(_baseUri, _relativeUrl);
    _httpClient.BaseAddress = _baseUri;
    // Add User Jwtoken
    _httpClient.DefaultRequestHeaders.Add("x-token", fp.GetJwToken());

    // Device Signature
    string shash = objectId + sin;
    string ssign = fp.Sign(shash);
    _httpClient.DefaultRequestHeaders.Add("x-jws-signature", ssign);

    HttpResponseMessage response = _httpClient.GetAsync(_uri).Result;
    if (response.IsSuccessStatusCode)
    {

        // Async download via SAS Uri
        string rsp = response.Content.ReadAsStringAsync().Result;
        VaultedResponse r = VaultedResponse.Decode(rsp);
        byte[]? objContent = r.GetUrlContent().Result;

        // Device unprotect 
        byte[] ContentBytes = fp.DeviceEcDhUnProtect(objContent, r.Jwk);
        string cnt = Encoding.UTF8.GetString(ContentBytes);
        Assert.AreEqual("Test", cnt);
    }
    else
    {
        // fail
        string error = response.Content.ReadAsStringAsync().Result;
        throw new Exception(error);
    }


}
